# Copy to backend/.env and fill in your values.

# Get an API key at https://resend.com
RESEND_API_KEY=re_your_api_key_here

# Where new form submissions are delivered
CONTACT_NOTIFY_EMAIL=team@vyncrafts.com

# Must be a verified sender in Resend (use onboarding@resend.dev for testing)
CONTACT_FROM_EMAIL=VynCrafts <team@vyncrafts.com>

# Optional
PORT=5000

# Set to true after running `pnpm run build` to serve the production site from dist/
SERVE_STATIC=true

# Comma-separated origins for cross-origin API access (optional when site and API share one host)
# ALLOWED_ORIGIN=https://vyncrafts.com,https://www.vyncrafts.com

# Enable only if local network blocks Resend HTTPS (dev only — do NOT use in production)
# RESEND_SKIP_TLS_VERIFY=true
